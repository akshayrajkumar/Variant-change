CLASS lcl_repo DEFINITION FINAL.
  PUBLIC SECTION.
    METHODS get_variants
       "IMPORTING iv_report          TYPE varid-report
      RETURNING VALUE(rt_variants) TYPE tt_variant_hdr.

    METHODS get_variant_contents
      IMPORTING iv_report  TYPE varid-report
                iv_variant TYPE varid-variant
      EXPORTING et_params  TYPE tt_rsparams.

    METHODS get_metadata
      IMPORTING iv_selname     TYPE rsparams-selname
      CHANGING  ct_cache       TYPE tt_meta
      RETURNING VALUE(rs_meta) TYPE ty_meta.
ENDCLASS.

CLASS lcl_eos_mapper DEFINITION FINAL.
  PUBLIC SECTION.
    METHODS load_mapping
      RETURNING VALUE(rt_map) TYPE tt_eos_map.

    METHODS process_variant_contents
      IMPORTING
        iv_report         TYPE varid-report
        iv_variant        TYPE varid-variant
        iv_variant_text   TYPE varit-vtext
        it_params         TYPE tt_rsparams
        it_map            TYPE tt_eos_map
      EXPORTING
        et_changed_params TYPE tt_rsparams
        et_change_output  TYPE tt_eos_change_out.

  PRIVATE SECTION.
    METHODS is_check_field
      IMPORTING iv_selname  TYPE rsparams-selname
      CHANGING  cv_flag     TYPE abap_bool
                cv_fieldnam TYPE char30.
ENDCLASS.


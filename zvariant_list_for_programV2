CLASS lcl_alv IMPLEMENTATION.
  METHOD display.
    DATA lo_alv TYPE REF TO cl_salv_table.
    DATA gt_output_alv TYPE tt_output.

    gt_output_alv = it_output.

    TRY.
        cl_salv_table=>factory(
          IMPORTING r_salv_table = lo_alv
          CHANGING  t_table      = gt_output_alv ).

        lo_alv->get_functions( )->set_all( abap_true ).
        lo_alv->get_columns( )->set_optimize( abap_true ).
        lo_alv->get_display_settings( )->set_list_header( 'Program Variant Details' ).
        lo_alv->get_display_settings( )->set_striped_pattern( abap_true ).

        TRY.
            lo_alv->get_columns( )->get_column( 'PROGRAM_NAME' )->set_short_text( 'Program' ).
            lo_alv->get_columns( )->get_column( 'VARIANT_NAME' )->set_short_text( 'Variant' ).
            lo_alv->get_columns( )->get_column( 'VARIANT_TEXT' )->set_short_text( 'Var Text' ).
            lo_alv->get_columns( )->get_column( 'SELECTION_FIELD' )->set_short_text( 'Field' ).
            lo_alv->get_columns( )->get_column( 'SELECTION_KIND' )->set_short_text( 'P/S' ).
            lo_alv->get_columns( )->get_column( 'LOW_VALUE' )->set_short_text( 'Low' ).
            lo_alv->get_columns( )->get_column( 'HIGH_VALUE' )->set_short_text( 'High' ).
            lo_alv->get_columns( )->get_column( 'DATA_ELEMENT' )->set_short_text( 'Data Elem' ).
            lo_alv->get_columns( )->get_column( 'REF_TABLE' )->set_short_text( 'Ref Table' ).
            lo_alv->get_columns( )->get_column( 'REF_FIELD' )->set_short_text( 'Ref Field' ).
            lo_alv->get_columns( )->get_column( 'DOMAIN' )->set_short_text( 'Domain' ).
          CATCH cx_salv_not_found.
        ENDTRY.

        lo_alv->display( ).
      CATCH cx_root INTO DATA(lx_root).
        MESSAGE lx_root->get_text( ) TYPE 'I'.
    ENDTRY.
  ENDMETHOD.

  METHOD display_change_output.
    DATA gt_output_alv TYPE tt_bukrs_change_out.

    gt_output_alv = it_output.

    TRY.
        cl_salv_table=>factory(
          IMPORTING r_salv_table = mo_alv
          CHANGING  t_table      = gt_output_alv ).

        mo_alv->get_functions( )->set_all( abap_true ).

        TRY.
            mo_alv->set_screen_status(
              pfstatus      = 'ZSALV_SAVE'
              report        = sy-repid
              set_functions = cl_salv_model_base=>c_functions_all ).
          CATCH cx_salv_method_not_supported.
        ENDTRY.

        mo_events =  mo_alv->get_event( ).
        SET HANDLER me->on_added_function FOR mo_events.

        mo_alv->get_columns( )->set_optimize( abap_true ).


        DATA lo_columns TYPE REF TO cl_salv_columns_table.
        DATA lo_column  TYPE REF TO cl_salv_column_table.

        lo_columns = mo_alv->get_columns( ).

        TRY.
            lo_column ?= lo_columns->get_column( 'PROGRAM_NAME' ).
            lo_column->set_short_text( 'Program' ).
            lo_column->set_medium_text( 'Program Name' ).
            lo_column->set_long_text( 'Executable Program Name' ).

            lo_column ?= lo_columns->get_column( 'VARIANT_NAME' ).
            lo_column->set_short_text( 'Variant' ).
            lo_column->set_medium_text( 'Variant Name' ).
            lo_column->set_long_text( 'Report Variant Name' ).

            lo_column ?= lo_columns->get_column( 'VARIANT_TEXT' ).
            lo_column->set_short_text( 'Text' ).
            lo_column->set_medium_text( 'Variant Text' ).
            lo_column->set_long_text( 'Variant Description' ).

            lo_column ?= lo_columns->get_column( 'SELECTION_FIELD' ).
            lo_column->set_short_text( 'Field' ).
            lo_column->set_medium_text( 'Selection Field' ).
            lo_column->set_long_text( 'Selection-Screen Field Name' ).

            lo_column ?= lo_columns->get_column( 'SELECTION_KIND' ).
            lo_column->set_short_text( 'P/S' ).
            lo_column->set_medium_text( 'Kind' ).
            lo_column->set_long_text( 'Parameter or Select-Option' ).

            lo_column ?= lo_columns->get_column( 'SIGN' ).
            lo_column->set_short_text( 'Sign' ).
            lo_column->set_medium_text( 'Sign' ).
            lo_column->set_long_text( 'Include/Exclude Sign' ).

            lo_column ?= lo_columns->get_column( 'OPTION' ).
            lo_column->set_short_text( 'Option' ).
            lo_column->set_medium_text( 'Option' ).
            lo_column->set_long_text( 'Selection Option' ).

            lo_column ?= lo_columns->get_column( 'OLD_LOW' ).
            lo_column->set_short_text( 'Old Low' ).
            lo_column->set_medium_text( 'Old Low Value' ).
            lo_column->set_long_text( 'Previous Low Value' ).
            lo_column ?= lo_columns->get_column( 'NEW_LOW' ).
            lo_column->set_short_text( 'New Low' ).
            lo_column->set_medium_text( 'New Low Value' ).
            lo_column->set_long_text( 'Changed Low Value' ).

            lo_column ?= lo_columns->get_column( 'OLD_HIGH' ).
            lo_column->set_short_text( 'Old High' ).
            lo_column->set_medium_text( 'Old High Value' ).
            lo_column->set_long_text( 'Previous High Value' ).

            lo_column ?= lo_columns->get_column( 'NEW_HIGH' ).
            lo_column->set_short_text( 'New High' ).
            lo_column->set_medium_text( 'New High Value' ).
            lo_column->set_long_text( 'Changed High Value' ).

            lo_column ?= lo_columns->get_column( 'CHANGED_IND' ).

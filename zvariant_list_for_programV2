            lo_column->set_medium_text( 'Changed Ind.' ).
            lo_column->set_long_text( 'Changed Indicator' ).

            lo_column ?= lo_columns->get_column( 'MESSAGE' ).
            lo_column->set_short_text( 'Message' ).
            lo_column->set_medium_text( 'Processing Message' ).
            lo_column->set_long_text( 'Change Processing Message' ).
          CATCH cx_salv_not_found.
        ENDTRY.
        mo_alv->get_display_settings( )->set_list_header( 'BUKRS Change Preview' ).
        mo_alv->get_display_settings( )->set_striped_pattern( abap_true ).

        mo_alv->display( ).


CLASS lcl_repo IMPLEMENTATION.
  METHOD get_variants.
    SELECT v~report,
           v~variant,
           v~ename,
           v~edat,
           t~vtext
      FROM varid AS v
      LEFT OUTER JOIN varit AS t
        ON t~report  = v~report
       AND t~variant = v~variant
       AND t~langu   = @sy-langu
      INTO TABLE @rt_variants
      WHERE v~report  = @iv_report
        AND v~variant IN @s_var.

    SORT rt_variants BY report variant.
  ENDMETHOD.

  METHOD get_variant_contents.
    CLEAR et_params.

    CALL FUNCTION 'RS_VARIANT_CONTENTS'
      EXPORTING
        report               = iv_report
        variant              = iv_variant
      TABLES
        valutab              = et_params
      EXCEPTIONS
        variant_non_existent = 1
        variant_obsolete     = 2
        OTHERS               = 3.

    IF sy-subrc <> 0.
      CLEAR et_params.
    ENDIF.
  ENDMETHOD.

  METHOD get_metadata.
    DATA lv_selname TYPE rsparams-selname.

    lv_selname = iv_selname.
    TRANSLATE lv_selname TO UPPER CASE.

    READ TABLE ct_cache WITH TABLE KEY selname = lv_selname INTO rs_meta.
    IF sy-subrc = 0.
      RETURN.
    ENDIF.

    CLEAR rs_meta.
    rs_meta-selname = lv_selname.

    SELECT SINGLE fieldname
                  rollname
                  checktable
                  domname
      FROM dd03l
      INTO (rs_meta-fieldname,
            rs_meta-rollname,
            rs_meta-checktable,
            rs_meta-domname)
      WHERE fieldname = lv_selname
        AND as4local  = 'A'.

    INSERT rs_meta INTO TABLE ct_cache.
  ENDMETHOD.
ENDCLASS.
*---------------------------------------------------------------------*
* Major block end: lcl_repo implementation
*---------------------------------------------------------------------*

*---------------------------------------------------------------------*
* Major block start: lcl_bukrs_mapper implementation
*---------------------------------------------------------------------*
CLASS lcl_bukrs_mapper IMPLEMENTATION.
  METHOD load_mapping.
*    SELECT old_value,
*           new_value
*      FROM zeos_bukrs
*      INTO TABLE @rt_map.
    SELECT field,
           old_value,
           new_value
    FROM zeos_value_tab
      INTO TABLE @rt_map.

  ENDMETHOD.

  METHOD is_bukrs_field.
    DATA lv_selname TYPE rsparams-selname.

    lv_selname = iv_selname.
    TRANSLATE lv_selname TO UPPER CASE.

    rv_bukrs = abap_false.

    IF lv_selname = 'BUKRS'
       OR lv_selname = 'P_BUKRS'
       OR lv_selname = 'S_BUKRS'
       OR lv_selname CP '*BUKRS'
       OR lv_selname = 'P_VKORG'
       OR lv_selname = 'S_VKORG'
       OR lv_selname CP '*VKORG'
       OR lv_selname = 'P_PRCTR'
       OR lv_selname = 'S_PRCTR'
       OR lv_selname CP '*PRCTR'
      .
      rv_bukrs = abap_true.
    ENDIF.
  ENDMETHOD.

  METHOD process_variant_contents.
    DATA ls_change_out TYPE ty_bukrs_change_out.
    DATA ls_param      TYPE rsparams.
    DATA ls_map        TYPE ty_eos_map.
    DATA lv_tabix      TYPE sy-tabix.

    et_changed_params = it_params.
    CLEAR et_change_output.

    LOOP AT et_changed_params INTO ls_param.
      lv_tabix = sy-tabix.

      IF is_bukrs_field( ls_param-selname ) = abap_false.
        CONTINUE.
      ENDIF.

      CLEAR ls_change_out.
      ls_change_out-program_name    = iv_report.
      ls_change_out-variant_name    = iv_variant.
      ls_change_out-variant_text    = iv_variant_text.
      ls_change_out-selection_field = ls_param-selname.
      ls_change_out-selection_kind  = ls_param-kind.
      ls_change_out-sign            = ls_param-sign.
      ls_change_out-option          = ls_param-option.
      ls_change_out-old_low         = ls_param-low.
      ls_change_out-old_high        = ls_param-high.
      ls_change_out-new_low         = ls_param-low.
      ls_change_out-new_high        = ls_param-high.
      ls_change_out-changed_ind     = abap_false.
      ls_change_out-message         = 'No mapping found'.

      READ TABLE it_map INTO ls_map WITH KEY field = 'BUKRS'
                                                   old_value = ls_param-low.
      "old_value = ls_param-low.
      IF sy-subrc = 0.
        ls_param-low              = ls_map-new_value.
        ls_change_out-new_low     = ls_map-new_value.
        ls_change_out-changed_ind = abap_true.
        ls_change_out-message     = 'LOW value of Company Code is changed from mapping table'.
      ENDIF.
      READ TABLE it_map INTO ls_map WITH KEY field = 'VKORG'
                                                  old_value = ls_param-low.
      IF sy-subrc = 0.
        ls_param-low              = ls_map-new_value.
        ls_change_out-new_low     = ls_map-new_value.
        ls_change_out-changed_ind = abap_true.
        ls_change_out-message     = 'LOW value of Sales Org is changed from mapping table'.
      ENDIF.
      READ TABLE it_map INTO ls_map WITH KEY field = 'PRCTR'
                                                  old_value = ls_param-low.
      IF sy-subrc = 0.
        ls_param-low              = ls_map-new_value.
        ls_change_out-new_low     = ls_map-new_value.
        ls_change_out-changed_ind = abap_true.
        ls_change_out-message     = 'LOW value Profit Center is changed from mapping table'.
      ENDIF.

      IF ls_param-high IS NOT INITIAL.
        READ TABLE it_map INTO ls_map WITH KEY old_value = ls_param-high.
        IF sy-subrc = 0.
          ls_param-high             = ls_map-new_value.
          ls_change_out-new_high    = ls_map-new_value.
          ls_change_out-changed_ind = abap_true.
          IF ls_change_out-message = 'LOW value changed from mapping table'.
            ls_change_out-message = 'LOW and HIGH changed from mapping table'.
          ELSE.
            ls_change_out-message = 'HIGH value changed from mapping table'.
          ENDIF.
        ENDIF.
      ENDIF.

      MODIFY et_changed_params FROM ls_param INDEX lv_tabix.
      APPEND ls_change_out TO et_change_output.
    ENDLOOP.
  ENDMETHOD.
ENDCLASS.

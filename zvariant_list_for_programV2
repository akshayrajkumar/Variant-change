        MESSAGE lx_salv->get_text( ) TYPE 'I'.
      CATCH cx_salv_method_not_supported INTO DATA(lx_not_sup).
        MESSAGE lx_not_sup->get_text( ) TYPE 'I'.
      CATCH cx_root INTO DATA(lx_root).
        MESSAGE lx_root->get_text( ) TYPE 'I'.
    ENDTRY.
  ENDMETHOD.

  METHOD on_added_function.
    CASE e_salv_function.
      WHEN 'ZSALV_SAVE'.
        LOOP AT gt_variant_save INTO DATA(ls_save).
          save_variant_changes(
            iv_report  = ls_save-report
            iv_variant = ls_save-variant
            it_params  = ls_save-params ).
        ENDLOOP.

        MESSAGE |{ lines( gt_variant_save ) } variant(s) processed for save| TYPE 'I'.
      WHEN 'BACK' OR 'EXIT' OR 'CANCEL'.
        LEAVE TO SCREEN 0.
    ENDCASE.
  ENDMETHOD.

  METHOD save_variant_changes.

    DATA ls_varid TYPE varid.
    CLEAR: ls_varid.
    SELECT SINGLE * FROM varid WHERE report = @iv_report AND variant = @iv_variant INTO @ls_varid.
    IF sy-subrc IS INITIAL.

    ENDIF.
    TRY.
        CALL FUNCTION 'RS_CHANGE_CREATED_VARIANT'
          EXPORTING
            curr_report               = iv_report
            curr_variant              = iv_variant
            vari_desc                 = ls_varid "_des-variant_text
            only_contents             = 'X'
          TABLES
            vari_contents             = it_params
*           VARI_CONTENTS_L           =
*           VARI_TEXT                 =
*           VARI_SEL_DESC             =
*           OBJECTS                   =
*           FREE_SELECTIONS_VALUE     =
*           FREE_SELECTIONS_OBJ       =
          EXCEPTIONS
            illegal_report_or_variant = 1
            illegal_variantname       = 2
            not_authorized            = 3
            not_executed              = 4
            report_not_existent       = 5
            report_not_supplied       = 6
            variant_doesnt_exist      = 7
            variant_locked            = 8
            selections_no_match       = 9
            OTHERS                    = 10.

      CATCH cx_sy_dyn_call_param_missing .
      CATCH cx_sy_no_handler.
    ENDTRY.
    IF sy-subrc <> 0.
      MESSAGE |Save failed for { iv_report } / { iv_variant }, subrc { sy-subrc }| TYPE 'I'.
    ENDIF.
  ENDMETHOD.

  METHOD download_tsv.
    DATA lt_lines TYPE STANDARD TABLE OF string WITH DEFAULT KEY.
    DATA lv_line  TYPE string.

    APPEND 'Program Name  Variant Name  Variant Text  Selection Field P/S Sign  Option  Low Value High Value  Data Element  Ref. Table  Ref. Field  Domain'
      TO lt_lines.

    LOOP AT it_output ASSIGNING FIELD-SYMBOL(<ls_out>).
      lv_line = |{ <ls_out>-program_name }  { <ls_out>-variant_name } { <ls_out>-variant_text } { <ls_out>-selection_field }  { <ls_out>-selection_kind } { <ls_out>-sign } { <ls_out>-option } { <ls_out>-low_value }  { <ls_out>-high_value } {
<ls_out>-data_element } { <ls_out>-ref_table }  { <ls_out>-ref_field }  { <ls_out>-domain }|.
      APPEND lv_line TO lt_lines.
    ENDLOOP.

    CALL FUNCTION 'GUI_DOWNLOAD'
      EXPORTING
        filename = |variant_list_{ sy-datum }_{ sy-uzeit }.xls|
        filetype = 'ASC'
      TABLES
        data_tab = lt_lines
      EXCEPTIONS
        OTHERS   = 1.
  ENDMETHOD.
ENDCLASS.

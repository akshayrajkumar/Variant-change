CLASS lcl_app IMPLEMENTATION.
  METHOD run.
    DATA lo_repo TYPE REF TO lcl_repo.
    DATA lo_alv  TYPE REF TO lcl_alv.
    DATA lo_bukrs_mapper TYPE REF TO lcl_bukrs_mapper.

    DATA lt_variants TYPE tt_variant_hdr.
    DATA lt_params   TYPE tt_rsparams.
    DATA lt_cache    TYPE tt_meta.
    DATA ls_output   TYPE ty_output.
    DATA ls_meta     TYPE ty_meta.
*    DATA lt_bukrs_map      TYPE tt_eos_map.
    DATA lt_eos_map      TYPE tt_eos_map.
    DATA lt_changed_params TYPE tt_rsparams.
    DATA lt_change_output  TYPE tt_bukrs_change_out.
    DATA gt_change_output  TYPE tt_bukrs_change_out.
    DATA lv_changed        TYPE abap_bool.

    lo_repo         = NEW lcl_repo( ).
    lo_alv          = NEW lcl_alv( ).
    lo_bukrs_mapper = NEW lcl_bukrs_mapper( ).


    IF p_bukchg = abap_true OR p_vkorg = abap_true OR p_prctr = abap_true.
      lt_eos_map = lo_bukrs_mapper->load_mapping( ).
    ENDIF.

    lt_variants = lo_repo->get_variants( iv_report = p_repid ).

    LOOP AT lt_variants ASSIGNING FIELD-SYMBOL(<ls_variant>).
      CLEAR: lt_params, lt_changed_params, lt_change_output.
      lo_repo->get_variant_contents(
        EXPORTING
          iv_report  = <ls_variant>-report
          iv_variant = <ls_variant>-variant
        IMPORTING
          et_params  = lt_params ).

      LOOP AT lt_params ASSIGNING FIELD-SYMBOL(<ls_param>).
        ls_meta = lo_repo->get_metadata(
                    EXPORTING
                      iv_selname = <ls_param>-selname
                    CHANGING
                      ct_cache   = lt_cache ).

        CLEAR ls_output.
        ls_output-program_name    = <ls_variant>-report.
        ls_output-variant_name    = <ls_variant>-variant.
        ls_output-variant_text    = <ls_variant>-vtext.
        ls_output-selection_field = <ls_param>-selname.
        ls_output-selection_kind  = <ls_param>-kind.
        ls_output-sign            = <ls_param>-sign.
        ls_output-option          = <ls_param>-option.
        ls_output-low_value       = <ls_param>-low.
        ls_output-high_value      = <ls_param>-high.
        ls_output-data_element    = ls_meta-rollname.
        ls_output-ref_table       = ls_meta-checktable.
        ls_output-ref_field       = ls_meta-fieldname.
        ls_output-domain          = ls_meta-domname.

        APPEND ls_output TO gt_output.

        IF p_max > 0 AND lines( gt_output ) >= p_max.
          EXIT.
        ENDIF.
      ENDLOOP.

      IF ( p_bukchg = abap_true OR p_vkorg = abap_true OR p_prctr = abap_true ) AND lt_eos_map IS NOT INITIAL.
        lo_bukrs_mapper->process_variant_contents(
          EXPORTING
            iv_report         = <ls_variant>-report
            iv_variant        = <ls_variant>-variant
            iv_variant_text   = <ls_variant>-vtext
            it_params         = lt_params
            it_map            = lt_eos_map
          IMPORTING
            et_changed_params = lt_changed_params
            et_change_output  = lt_change_output ).

        APPEND LINES OF lt_change_output TO gt_change_output.

        lv_changed = abap_false.
*        LOOP AT lt_change_output ASSIGNING FIELD-SYMBOL(<ls_change>) WHERE changed_ind = abap_true.
*          lv_changed = abap_true.
*          EXIT.
*        ENDLOOP.
        lv_changed = xsdbool( line_exists( lt_change_output[ changed_ind = abap_true ] ) ).

        IF lv_changed = abap_true.
          DELETE gt_variant_save
            WHERE report  = <ls_variant>-report
              AND variant = <ls_variant>-variant.

          APPEND VALUE ty_variant_save(
            report  = <ls_variant>-report
            variant = <ls_variant>-variant
            params  = lt_changed_params ) TO gt_variant_save.
        ENDIF.
      ENDIF.

      IF p_max > 0 AND lines( gt_output ) >= p_max.
        EXIT.
      ENDIF.
    ENDLOOP.

    IF p_bukchg = abap_true.
      lo_alv->display_change_output( gt_change_output ).
    ELSE.
      lo_alv->display( gt_output ).

      IF p_xls = abap_true.
        lo_alv->download_tsv( it_output = gt_output ).
      ENDIF.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

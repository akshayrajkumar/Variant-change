*---------------------------------------------------------------------*
* Major block start: lcl_app implementation
*---------------------------------------------------------------------*
CLASS lcl_app IMPLEMENTATION.
  METHOD run.
    DATA lo_repo TYPE REF TO lcl_repo.
    DATA lo_alv  TYPE REF TO lcl_alv.
    DATA lo_eos_mapper TYPE REF TO lcl_eos_mapper.
    DATA lt_variants TYPE tt_variant_hdr.
    DATA lt_params   TYPE tt_rsparams.
    DATA lt_cache    TYPE tt_meta.
    DATA ls_output   TYPE ty_output.
    DATA ls_meta     TYPE ty_meta.
    DATA lt_eos_map      TYPE tt_eos_map.
    DATA lt_changed_params TYPE tt_rsparams.
    DATA lt_change_output  TYPE tt_eos_change_out.
    DATA gt_change_output  TYPE tt_eos_change_out.
    DATA lv_changed        TYPE abap_bool.

    lo_repo         = NEW lcl_repo( ).
    lo_alv          = NEW lcl_alv( ).
    lo_eos_mapper   = NEW lcl_eos_mapper( ).

      SELECT *
      FROM zfieldcombi
      INTO TABLE gt_fieldcombi
      WHERE field IN s_field.
    
IF gt_fieldcombi IS NOT INITIAL.
      LOOP AT gt_fieldcombi INTO DATA(ls_combi).
        ls_field_wa-sign   = 'I'.
        ls_field_wa-option = 'CP'.
        ls_field_wa-low    = |*{ ls_combi-field_alias }|.

        APPEND ls_field_wa TO s_field.
      ENDLOOP.
    ENDIF.
    IF p_eos = abap_true.
      lt_eos_map = lo_eos_mapper->load_mapping( ).
    ENDIF.

    lt_variants = lo_repo->get_variants( iv_report = p_repid ).

    LOOP AT lt_variants ASSIGNING FIELD-SYMBOL(<ls_variant>).
      CLEAR: lt_params, lt_changed_params, lt_change_output.
      lo_repo->get_variant_contents(
        EXPORTING
          iv_report  = <ls_variant>-report
          iv_variant = <ls_variant>-variant
        IMPORTING
          et_params  = lt_params ).

      IF p_eos = abap_false.
        LOOP AT lt_params ASSIGNING FIELD-SYMBOL(<ls_param>).
          ls_meta = lo_repo->get_metadata(
                      EXPORTING
                        iv_selname = <ls_param>-selname
                      CHANGING
                        ct_cache   = lt_cache ).

          CLEAR ls_output.
          ls_output-program_name    = <ls_variant>-report.
          ls_output-variant_name    = <ls_variant>-variant.
          ls_output-variant_text    = <ls_variant>-vtext.
          ls_output-selection_field = <ls_param>-selname.
          ls_output-selection_kind  = <ls_param>-kind.
          ls_output-sign            = <ls_param>-sign.
          ls_output-option          = <ls_param>-option.
          ls_output-low_value       = <ls_param>-low.
          ls_output-high_value      = <ls_param>-high.
          ls_output-data_element    = ls_meta-rollname.
          ls_output-ref_table       = ls_meta-checktable.
          ls_output-ref_field       = ls_meta-fieldname.
          ls_output-domain          = ls_meta-domname.

          APPEND ls_output TO gt_output.

          IF p_max > 0 AND lines( gt_output ) >= p_max.
            EXIT.
          ENDIF.
        ENDLOOP.
      ENDIF.

      IF   p_eos = abap_true AND lt_eos_map IS NOT INITIAL.
        lo_eos_mapper->process_variant_contents(
          EXPORTING
            iv_report         = <ls_variant>-report
            iv_variant        = <ls_variant>-variant
            iv_variant_text   = <ls_variant>-vtext
            it_params         = lt_params
            it_map            = lt_eos_map
          IMPORTING
            et_changed_params = lt_changed_params
            et_change_output  = lt_change_output ).

        APPEND LINES OF lt_change_output TO gt_change_output.

        lv_changed = abap_false.

        lv_changed = xsdbool( line_exists( lt_change_output[ changed_ind = abap_true ] ) ).

        IF lv_changed = abap_true.
          DELETE gt_variant_save
            WHERE report  = <ls_variant>-report
              AND variant = <ls_variant>-variant.

          APPEND VALUE ty_variant_save(
            report  = <ls_variant>-report
            variant = <ls_variant>-variant
            params  = lt_changed_params ) TO gt_variant_save.
        ENDIF.
      ENDIF.

      IF p_max > 0 AND lines( gt_output ) >= p_max.
        EXIT.
      ENDIF.
    ENDLOOP.

    IF p_eos = abap_true.
      lo_alv->display_change_output( gt_change_output ).
    ELSE.
      lo_alv->display( gt_output ).

      IF p_xls = abap_true.
        lo_alv->download_tsv( it_output = gt_output ).
      ENDIF.
    ENDIF.
  ENDMETHOD.
  METHOD run_tvarvc.
    DATA: lv_like       TYPE string,
          lt_tvarvc     TYPE STANDARD TABLE OF tvarvc,
          lt_tvarvc_upd TYPE STANDARD TABLE OF tvarvc,
          ls_tvarvc_dis TYPE ty_tvarvc,
          lt_tvarvc_dis TYPE tt_tvarvc,
          lt_zeos       TYPE HASHED TABLE OF zeos_value_tab WITH UNIQUE KEY old_value,
          ls_tvarvc     TYPE tvarvc,
          ls_zeos       TYPE zeos_value_tab,
          lv_changed    TYPE abap_bool,
          lo_alv        TYPE REF TO lcl_alv.

    lv_like = |%{ p_pat }%|.

    SELECT *
      FROM tvarvc
      INTO TABLE @lt_tvarvc
      WHERE name LIKE @lv_like
      ORDER BY PRIMARY KEY.

    IF lt_tvarvc IS INITIAL.
      DATA(lv_msg) = | No TVARVC entries matched pattern: { p_pat } |.
      MESSAGE lv_msg TYPE 'E' DISPLAY LIKE 'I'.
      EXIT.
    ENDIF.

    DATA(lv_pattern) = p_pat.
    IF lv_pattern = 'PLANT'.
      lv_pattern = 'WERKS'.
    ENDIF.

    SELECT *
      FROM zeos_value_tab
      INTO TABLE @lt_zeos
      WHERE field = @lv_pattern.

    IF lt_zeos IS INITIAL.
      DATA(no_val) = abap_true.
*      MESSAGE 'No entries found in ZEOS_VALUE_TAB' TYPE 'S' DISPLAY LIKE 'I'.
*      EXIT.
    ENDIF.

    LOOP AT lt_tvarvc INTO ls_tvarvc.
      lv_changed = abap_false.

      IF ls_tvarvc-name CS p_pat.
        READ TABLE lt_zeos INTO ls_zeos WITH KEY field = p_pat
                                                 old_value = ls_tvarvc-low.
        IF sy-subrc = 0.
          ls_tvarvc_dis-old_val_l = ls_tvarvc-low.
          ls_tvarvc-low           = ls_zeos-new_value.
          lv_changed              = abap_true.
          MOVE-CORRESPONDING ls_tvarvc TO ls_tvarvc_dis.
        ELSE.
          MOVE-CORRESPONDING ls_tvarvc TO ls_tvarvc_dis.
        ENDIF.

        READ TABLE lt_zeos INTO ls_zeos WITH KEY field = p_pat
                                                 old_value = ls_tvarvc-high.
        IF sy-subrc = 0.
          ls_tvarvc_dis-old_val_h = ls_tvarvc-high.
          ls_tvarvc-high = ls_zeos-new_value.
          lv_changed = abap_true.
          MOVE-CORRESPONDING ls_tvarvc TO ls_tvarvc_dis.
        ELSE.
          MOVE-CORRESPONDING ls_tvarvc TO ls_tvarvc_dis.
        ENDIF.

      ENDIF.

      IF lv_changed = abap_true.
        APPEND ls_tvarvc TO lt_tvarvc_upd.
        APPEND ls_tvarvc_dis TO lt_tvarvc_dis.
      ELSE.
        APPEND ls_tvarvc_dis TO lt_tvarvc_dis.
      ENDIF.
    ENDLOOP.

    IF p_test = abap_false.
      IF lt_tvarvc_upd IS INITIAL.
        MESSAGE 'No matching LOW/HIGH values found in Table ZEOS_VALUE_TAB for update' TYPE 'S'.
        LEAVE LIST-PROCESSING.
      ENDIF.
    ENDIF.

    lo_alv = NEW lcl_alv( ) .
    IF p_test = abap_true.
      lo_alv->display_tvarvc( EXPORTING it_output = lt_tvarvc_dis
                                        iv_header = 'TVARVC Table update TEST MODE' ).
    ELSE.
      DATA lv_ans TYPE char1.
      CALL FUNCTION 'POPUP_TO_CONFIRM'
        EXPORTING
          titlebar              = 'Confirm Action'
          text_question         = 'Confirm to Update TVARVC Table'
          text_button_1         = 'Update'
          icon_button_1         = 'ICON_OKAY'
          text_button_2         = 'Cancel'
          icon_button_2         = 'ICON_CANCEL'
          default_button        = '2'
          display_cancel_button = space
        IMPORTING
          answer                = lv_ans
        EXCEPTIONS
          text_not_found        = 1
          OTHERS                = 2.
      CASE lv_ans.
        WHEN 1.
          MODIFY tvarvc FROM TABLE @lt_tvarvc_upd.

          IF sy-subrc IS INITIAL.
            lo_alv->display_tvarvc( EXPORTING it_output = lt_tvarvc_dis
                                              iv_header = 'TVARVC updated successfully' ).
          ELSE.
            lo_alv->display_tvarvc( EXPORTING it_output = lt_tvarvc_dis
                                              iv_header = 'TVARVC updated Failed' ).
          ENDIF.

        WHEN OTHERS.
          MESSAGE 'Updating TVARVC table Cancelled.' TYPE 'S'.
          LEAVE TO SCREEN 0.
      ENDCASE.
    ENDIF.
  ENDMETHOD.
ENDCLASS.

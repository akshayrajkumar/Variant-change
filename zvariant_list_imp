            lo_column->set_short_text( 'Option' ).
            lo_column->set_medium_text( 'Option' ).
            lo_column->set_long_text( 'Selection Option' ).

            lo_column ?= lo_columns->get_column( 'OLD_LOW' ).
            lo_column->set_short_text( 'Old Low' ).
            lo_column->set_medium_text( 'Old Low Value' ).
            lo_column->set_long_text( 'Previous Low Value' ).
            lo_column ?= lo_columns->get_column( 'NEW_LOW' ).
            lo_column->set_short_text( 'New Low' ).
            lo_column->set_medium_text( 'New Low Value' ).
            lo_column->set_long_text( 'Changed Low Value' ).

            lo_column ?= lo_columns->get_column( 'OLD_HIGH' ).
            lo_column->set_short_text( 'Old High' ).
            lo_column->set_medium_text( 'Old High Value' ).
            lo_column->set_long_text( 'Previous High Value' ).

            lo_column ?= lo_columns->get_column( 'NEW_HIGH' ).
            lo_column->set_short_text( 'New High' ).
            lo_column->set_medium_text( 'New High Value' ).
            lo_column->set_long_text( 'Changed High Value' ).

            lo_column ?= lo_columns->get_column( 'CHANGED_IND' ).
            lo_column->set_short_text( 'Changed' ).
            lo_column->set_medium_text( 'Changed Ind.' ).
            lo_column->set_long_text( 'Changed Indicator' ).

            lo_column ?= lo_columns->get_column( 'MESSAGE' ).
            lo_column->set_short_text( 'Message' ).
            lo_column->set_medium_text( 'Processing Message' ).

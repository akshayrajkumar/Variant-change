        lo_alv->get_functions( )->set_all( abap_true ).
        lo_alv->get_columns( )->set_optimize( abap_true ).
        lo_alv->get_display_settings( )->set_list_header( 'Program Variant Details' ).
        lo_alv->get_display_settings( )->set_striped_pattern( abap_true ).

        TRY.
            lo_alv->get_columns( )->get_column( 'PROGRAM_NAME' )->set_short_text( 'Program' ).
            lo_alv->get_columns( )->get_column( 'VARIANT_NAME' )->set_short_text( 'Variant' ).
            lo_alv->get_columns( )->get_column( 'VARIANT_TEXT' )->set_short_text( 'Var Text' ).
            lo_alv->get_columns( )->get_column( 'SELECTION_FIELD' )->set_short_text( 'Field' ).
            lo_alv->get_columns( )->get_column( 'SELECTION_KIND' )->set_short_text( 'P/S' ).
            lo_alv->get_columns( )->get_column( 'LOW_VALUE' )->set_short_text( 'Low' ).
            lo_alv->get_columns( )->get_column( 'HIGH_VALUE' )->set_short_text( 'High' ).
            lo_alv->get_columns( )->get_column( 'DATA_ELEMENT' )->set_short_text( 'Data Elem' ).
            lo_alv->get_columns( )->get_column( 'REF_TABLE' )->set_short_text( 'Ref Table' ).
            lo_alv->get_columns( )->get_column( 'REF_FIELD' )->set_short_text( 'Ref Field' ).

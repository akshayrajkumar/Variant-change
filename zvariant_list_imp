            lo_column->set_short_text( 'Variant' ).
            lo_column->set_medium_text( 'Variant Name' ).
            lo_column->set_long_text( 'Report Variant Name' ).

            lo_column ?= lo_columns->get_column( 'VARIANT_TEXT' ).
            lo_column->set_short_text( 'Text' ).
            lo_column->set_medium_text( 'Variant Text' ).
            lo_column->set_long_text( 'Variant Description' ).

